# Copy to .env, edit, then `docker compose up -d`.

# --- Required ---
# Admin password (config editing). Must NOT be empty or the literal 'changeme'.
ADMIN_PASSWORD=change-this-now

# --- Viewer gate (site-wide password wall) ---
# Everyone visiting the site must enter this before seeing the dashboard.
# 3 wrong attempts locks that IP out for 15 minutes.
# Leave empty to use the built-in default password.
VIEWER_PASSWORD=

# --- Optional knobs ---
GRAIL_HOST_PORT=6093

# Set true when grail is served over HTTPS (marks cookies Secure).
SECURE_COOKIES=false

# Reverse-proxy CIDRs whose X-Forwarded-For header is trusted for the real
# client IP (used by login/gate rate limiting). Leave empty if grail is exposed
# directly — otherwise every visitor looks like the proxy and one lockout would
# lock everyone. Behind nginx/traefik on the docker bridge, use e.g.:
#   TRUSTED_PROXIES=172.16.0.0/12,127.0.0.1/32
TRUSTED_PROXIES=

# Skip TLS certificate verification on uptime checks (for self-signed internal
# hosts). Defaults to false; only enable if you check https hosts with bad certs.
INSECURE_SKIP_VERIFY=false

# Log verbosity: debug | info | warn | error (default info).
# info shows check up/down transitions, logins, config saves and errors.
# debug additionally logs every HTTP request (noisy).
LOG_LEVEL=info

# --- Optional Umami analytics (off by default) ---
# To enable: bring up an Umami instance, register a website, and paste both:
#   UMAMI_SCRIPT_URL=https://your-umami-host/script.js
#   UMAMI_WEBSITE_ID=<UUID from Umami Settings → Websites>
# Then `docker compose up -d` picks them up.
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
