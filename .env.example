# Copy to .env, edit, then `docker compose up -d`.

# --- Required ---
ADMIN_PASSWORD=changeme

# --- Optional knobs ---
GRAIL_HOST_PORT=6093
INSECURE_SKIP_VERIFY=true

# --- Optional Umami analytics (off by default) ---
# To enable: bring up an Umami instance, register a website, and paste both:
#   UMAMI_SCRIPT_URL=https://your-umami-host/script.js
#   UMAMI_WEBSITE_ID=<UUID from Umami Settings → Websites>
# Then `docker compose up -d` picks them up.
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
